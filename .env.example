# RedRising HedgeFund — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── LLM API Keys ─────────────────────────────────────────────────────────────
# DeepSeek (reasoning model)
DEEPSEEK_API_KEY=your_deepseek_key_here

# OpenAI (GPT-4o fallback)
OPENAI_API_KEY=your_openai_key_here

# MiniMax (researcher B + risk manager)
MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# Anthropic (Claude — optional)
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Local Inference ───────────────────────────────────────────────────────────
# MLX server endpoint (M5 Max or Apple Silicon)
MLX_HOST=http://localhost:8080

# Ollama endpoint (embedding model)
OLLAMA_HOST=http://localhost:11434

# ── Infrastructure ────────────────────────────────────────────────────────────
# EC2 or remote server
EC2_HOST=your.ec2.instance.ip
EC2_KEY_PATH=data/your-ec2-key.pem

# ── Alerting ─────────────────────────────────────────────────────────────────
# Telegram bot for alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ── Exchange (configure for your venue) ──────────────────────────────────────
# Example: private key for signing orders (NEVER hardcode, always from env)
WALLET_PRIVATE_KEY=your_private_key_here
